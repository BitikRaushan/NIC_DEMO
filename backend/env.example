# ──────────────────────────────────────────────────────────────────────────────
# QueryBridge Backend – Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Flask ────────────────────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true
SECRET_KEY=change-me-in-production
AUTH_TOKEN_TTL_SECONDS=604800

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=querybridge
PG_USER=postgres
PG_PASSWORD=your_password_here
PG_VERSION=16
PG_SSLMODE=require

# Connection pool
PG_MIN_CONN=1
PG_MAX_CONN=10

# ─── Ollama LLM ───────────────────────────────────────────────────────────────
# Make sure Ollama is running: ollama serve
# Pull a model first:          ollama pull llama3
#                          or: ollama pull qwen2.5-coder
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=30

# ─── Safety ───────────────────────────────────────────────────────────────────
MAX_PROMPT_LENGTH=500

DATABASE_URL="postgresql://postgres:your_password@localhost:5432/adminposgre"